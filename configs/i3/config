set $mod Mod4
font pango:Hack 12
floating_modifier $mod

set $term kitty
set $browser firefox
set $files thunar

bindsym $mod+t exec $term
bindsym $mod+w exec $browser
bindsym $mod+e exec $files
bindsym $mod+q kill

# bindsym ctrl+space exec "rofi -show combi -modi window,run,combi -combi-modi window,run"
bindsym $mod+c exec opencode-desktop
bindsym $mod+d exec AyuGram
bindsym F12 exec ~/.config/i3/rofi-toggle.sh

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+Shift+t split toggle
bindsym $mod+f fullscreen toggle

bindsym $mod+s layout stacking
bindsym $mod+Tab layout tabbed
bindsym $mod+Shift+e layout toggle split

bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

workspace 1 output DisplayPort-1
workspace 2 output DisplayPort-1
workspace 3 output DisplayPort-1
workspace 4 output DisplayPort-1
workspace 5 output DisplayPort-1
workspace 6 output HDMI-A-1-1
workspace 7 output HDMI-A-1-1
workspace 8 output HDMI-A-1-1
workspace 9 output HDMI-A-1-1
workspace 10 output HDMI-A-1-1

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Mod1+1 move container to workspace number $ws1; workspace number $ws1
bindsym $mod+Mod1+2 move container to workspace number $ws2; workspace number $ws2
bindsym $mod+Mod1+3 move container to workspace number $ws3; workspace number $ws3
bindsym $mod+Mod1+4 move container to workspace number $ws4; workspace number $ws4
bindsym $mod+Mod1+5 move container to workspace number $ws5; workspace number $ws5
bindsym $mod+Mod1+6 move container to workspace number $ws6; workspace number $ws6
bindsym $mod+Mod1+7 move container to workspace number $ws7; workspace number $ws7
bindsym $mod+Mod1+8 move container to workspace number $ws8; workspace number $ws8
bindsym $mod+Mod1+9 move container to workspace number $ws9; workspace number $ws9
bindsym $mod+Mod1+0 move container to workspace number $ws10; workspace number $ws10

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+q exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

mode "resize" {
        bindsym Left resize shrink width 5 px or 5 ppt
        bindsym Down resize grow height 5 px or 5 ppt
        bindsym Up resize shrink height 5 px or 5 ppt
        bindsym Right resize grow width 5 px or 5 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

exec --no-startup-id xautolock -time 10 -locker "betterlockscreen -l" -killtime 20 -killer "xset dpms force off" -detectsleep &
exec --no-startup-id dbus-update-activation-environment --all
exec_always --no-startup-id sh -c 'export XDG_CURRENT_DESKTOP=i3; export XDG_SESSION_TYPE=x11; /usr/lib/xdg-desktop-portal'
exec --no-startup-id gsettings set org.gnome.desktop.interface gtk-theme 'Nordic'
exec --no-startup-id gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
exec --no-startup-id ~/.config/polybar/launch.sh

gaps top 36
gaps inner 6
gaps outer 4

include ~/.config/i3/colors



for_window [title="Calculator"] floating enable
for_window [title="Timer"] floating enable
for_window [class="^.*"] border pixel 3
for_window [class="firefox"] border none
for_window [class="mpv"] floating enable
for_window [class="imv"] floating enable
for_window [class="zenity"] floating enable
for_window [class="Thunar"] floating enable

bindsym XF86AudioRaiseVolume exec "pamixer -ui 3 && pamixer --get-volume > /tmp/xobpipe"
bindsym XF86AudioLowerVolume exec "pamixer -ud 3 && pamixer --get-volume > /tmp/xobpipe"
bindsym XF86AudioMute exec "amixer sset Master toggle | sed -En '/\[on\]/ s/.*\[([0-9]+)%\].*/\1/ p; /\[off\]/ s/.*/0/p' | head -1 > /tmp/xobpipe"

bindsym $mod+Shift+p exec gnome-calculator
bindsym $mod+p floating toggle; sticky toggle; resize set 480 270
bindsym $mod+l exec betterlockscreen -l

bindsym Print exec ~/.config/i3/screenshot.sh area
bindsym $mod+Shift+s exec ~/.config/i3/screenshot.sh area
bindsym $mod+Print exec ~/.config/i3/screenshot.sh full

bindsym $mod+c exec kitty -e opencode
bindsym $mod+b exec blueman-manager
bindsym $mod+Shift+w exec python3 ~/.config/i3/wallpaper-menu.py
bindsym $mod+Shift+Return exec $term

exec_always setxkbmap -option grp:caps_toggle "us,ru" -option "grp:caps_toggle,grp_led:caps"
exec_always --no-startup-id xcape -e 'Super_L=F12'

exec xrandr --output HDMI-A-1-1 --mode 1440x900 --rate 74.98 --pos 0x0 --output DisplayPort-1 --mode 1920x1080 --rate 240 --pos 1440x0 --primary

exec --no-startup-id ~/.config/i3/restore-wallpaper.sh
exec --no-startup-id sh -c 'sleep 3 && xsetroot -cursor_name left_ptr'

exec --no-startup-id picom
exec --no-startup-id dunst
exec --no-startup-id udiskie --tray
exec --no-startup-id blueman-applet
exec --no-startup-id dex -a -s /etc/xdg/autostart/:~/.config/autostart/
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

exec_always mkfifo /tmp/xobpipe && tail -f /tmp/xobpipe | xob -t 2170 & disown
